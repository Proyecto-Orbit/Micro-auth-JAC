# Puerto HTTP del microservicio
PORT=3000

# Origenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:5173

# Configuracion del servidor Keycloak
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=jac-project

# Cliente confidencial con service-account habilitado y rol realm-management
# (manage-users, query-users, view-users) asignado al service-account-<client>
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli-service
KEYCLOAK_ADMIN_CLIENT_SECRET=replace-me

# Cliente publico usado por el frontend - se usa para validar el aud del access token entrante
KEYCLOAK_PUBLIC_CLIENT_ID=frontend-client
